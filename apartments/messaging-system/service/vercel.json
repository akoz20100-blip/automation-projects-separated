{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    { "path": "/api/cron/evening", "schedule": "0 20 * * *" },
    { "path": "/api/cron/midday", "schedule": "0 9 * * *" }
  ]
}
