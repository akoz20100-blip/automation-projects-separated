{
  "name": "apartment-guest-messaging-service",
  "version": "1.0.0",
  "private": true,
  "description": "Cloud API for apartment guest messaging: OCR intake, WhatsApp Cloud API sending, and per-apartment landing pages.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "build:pages": "tsx scripts/build-pages.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.10",
    "sharp": "^0.34.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
