# ---- App ----
APP_ENV=development
PORT=3000
API_SECRET=local_secret
DEFAULT_TIMEZONE=Asia/Riyadh

# WhatsApp sending mode: cloud_api | wasender | manual_link
# - manual_link: returns wa.me links (no credentials needed)
# - wasender:    send free-form text via WasenderAPI now (no Meta template approval)
# - cloud_api:   send approved templates via Meta Graph API
WHATSAPP_MODE=manual_link

# ---- WasenderAPI (third-party WhatsApp gateway) ----
WASENDER_API_KEY=
WASENDER_API_URL=https://www.wasenderapi.com/api/send-message

# ---- WhatsApp Business Cloud API (Meta Graph API) ----
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Approved template names (Arabic + English variants)
WA_TEMPLATE_ACCESS_AR=apt_access_ar
WA_TEMPLATE_ACCESS_EN=apt_access_en
WA_TEMPLATE_CHECKOUT_AR=apt_checkout_ar
WA_TEMPLATE_CHECKOUT_EN=apt_checkout_en
WA_TEMPLATE_REVIEW_AR=apt_review_ar
WA_TEMPLATE_REVIEW_EN=apt_review_en

# ---- OCR (OpenAI-compatible provider, e.g. OpenRouter / your aggregator) ----
# Use a strong, accurate multilingual vision model (Arabic + English).
# Recommended (high accuracy): google/gemini-3.5-flash
# Stronger alternatives: qwen/qwen3-vl-235b-a22b-instruct, google/gemini-2.5-pro
# Cheaper alternative: google/gemini-2.5-flash-lite
OCR_API_BASE_URL=https://openrouter.ai/api/v1
OCR_API_KEY=
OCR_MODEL=google/gemini-3.5-flash

# ---- Google Sheets (data store) ----
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key with literal \n escapes or wrap in quotes with real newlines.
GOOGLE_PRIVATE_KEY=

# ---- Landing page ----
LANDING_BASE_URL=https://your-app.vercel.app
BRAND_LOGO_URL=
# Accent colour. Leave as the legacy default to use the Dimora brand sage green
# (#889970); set any other value to override the page accent.
BRAND_PRIMARY_COLOR=#889970
BRAND_SECONDARY_COLOR=#F4F1EA

# ---- Owner notifications (new booking, checkout reminder, checkout check) ----
OWNER_NOTIFY_ENABLED=true
OWNER_PHONE=

# ---- Cleaner notification (one cleaner for all apartments) ----
CLEANER_NOTIFY_ENABLED=true
CLEANER_PHONE=
CLEANER_NAME=Sara

# ---- Scheduler (Vercel Cron) ----
# Protects the daily /api/cron/* jobs. Vercel automatically sends
# "Authorization: Bearer <CRON_SECRET>" to the scheduled runs (see vercel.json):
#   /api/cron/evening  23:00 Riyadh  -> checkout reminder + owner/cleaner "checkout"
#   /api/cron/midday   12:00 Riyadh  -> owner/cleaner "check" + review request
CRON_SECRET=

# ---- Telegram intake bot ----
# The owner/team forward a booking screenshot to the bot -> OCR -> reservation.
TELEGRAM_BOT_TOKEN=
# Secret token returned by Telegram in the X-Telegram-Bot-Api-Secret-Token header
# (set at setWebhook time). Verifies that webhook calls really come from Telegram.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated chat IDs allowed to use the bot. Empty -> anyone. Lock it to the
# owner + team once you have their IDs (the bot replies with each chat id on /start).
TELEGRAM_ALLOWED_CHAT_IDS=
# Apartment used when a screenshot caption doesn't specify D1/D2.
TELEGRAM_DEFAULT_APARTMENT_ID=apt_01

# ---- TTLock smart locks (TTLock Open Platform) ----
# Per booking, the bot issues a keyboard passcode = LAST 4 DIGITS of the guest's
# phone, valid from check-in (16:00) to checkout (12:00) in DEFAULT_TIMEZONE.
#
# Region: the EU developer console (euopen.ttlock.com) uses the EU API host below.
# Global cloud is https://api.ttlock.com.
TTLOCK_API_BASE_URL=https://euapi.ttlock.com
# From your TTLock Open Platform app (console shows client_id; click "View" for the secret).
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
# The TTLock APP account that owns the locks (phone or email) + its password.
TTLOCK_USERNAME=
TTLOCK_PASSWORD=
# Map each apartment to its lockId. Discover lockIds via GET /api/ttlock/locks
# once the four values above are set. Format: apt_01:1234567,apt_02:7654321
TTLOCK_LOCKS=
# Passcode validity window (local time). Used only if the reservation has no time.
TTLOCK_CHECKIN_TIME=16:00
TTLOCK_CHECKOUT_TIME=12:00
# 2 = add the code remotely via a WiFi gateway (REQUIRED for a custom last-4 code).
TTLOCK_ADD_TYPE=2
# If the custom add fails (e.g. no gateway), fall back to a system-generated,
# gateway-free period code (NOT the last-4-of-phone). true/false.
TTLOCK_FALLBACK_TO_GENERATED=false
