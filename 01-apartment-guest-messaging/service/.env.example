# ---- App ----
APP_ENV=development
PORT=3000
API_SECRET=local_secret
DEFAULT_TIMEZONE=Asia/Riyadh

# WhatsApp sending mode: cloud_api | wasender | manual_link
# - manual_link: returns wa.me links (no credentials needed)
# - wasender:    send free-form text via WasenderAPI now (no Meta template approval)
# - cloud_api:   send approved templates via Meta Graph API
WHATSAPP_MODE=manual_link

# ---- WasenderAPI (third-party WhatsApp gateway) ----
WASENDER_API_KEY=
WASENDER_API_URL=https://www.wasenderapi.com/api/send-message

# ---- WhatsApp Business Cloud API (Meta Graph API) ----
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Approved template names (Arabic + English variants)
WA_TEMPLATE_ACCESS_AR=apt_access_ar
WA_TEMPLATE_ACCESS_EN=apt_access_en
WA_TEMPLATE_CHECKOUT_AR=apt_checkout_ar
WA_TEMPLATE_CHECKOUT_EN=apt_checkout_en
WA_TEMPLATE_REVIEW_AR=apt_review_ar
WA_TEMPLATE_REVIEW_EN=apt_review_en

# ---- OCR (OpenAI-compatible provider, e.g. OpenRouter / your aggregator) ----
# Use a strong, accurate multilingual vision model (Arabic + English).
# Recommended (high accuracy): google/gemini-3.5-flash
# Stronger alternatives: qwen/qwen3-vl-235b-a22b-instruct, google/gemini-2.5-pro
# Cheaper alternative: google/gemini-2.5-flash-lite
OCR_API_BASE_URL=https://openrouter.ai/api/v1
OCR_API_KEY=
OCR_MODEL=google/gemini-3.5-flash

# ---- Google Sheets (data store) ----
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key with literal \n escapes or wrap in quotes with real newlines.
GOOGLE_PRIVATE_KEY=

# ---- Landing page ----
LANDING_BASE_URL=https://your-app.vercel.app
BRAND_LOGO_URL=
BRAND_PRIMARY_COLOR=#0E7C66
BRAND_SECONDARY_COLOR=#F4F1EA

# ---- Owner notifications (new booking, checkout reminder, checkout check) ----
OWNER_NOTIFY_ENABLED=true
OWNER_PHONE=

# ---- Cleaner notification (one cleaner for all apartments) ----
CLEANER_NOTIFY_ENABLED=true
CLEANER_PHONE=
